  "keyFeatures": [
    "Multi-platform support: iOS, iPadOS, macOS, and visionOS",
    "Multi-account management with secure keychain storage",
    "Real-time streaming timeline with unread counters",
    "Full-featured post composer with AI-assisted tools (OpenAI)",
    "Rich push notifications via custom privacy-preserving proxy",
    "Extensive theming with 14+ built-in color sets and custom themes",
    "Tag groups — custom timelines combining multiple hashtags",
    "Remote local timelines from any Mastodon instance",
    "Home screen widgets (timeline, mentions, hashtags, accounts)",
    "Translation support via DeepL and instance-provided translations",
    "iCloud sync for tag groups, remote timelines, and drafts",
    "Home timeline caching with position sync across devices"
  ],
  "publicApiSurface": [
    "MastodonClient.get(endpoint:forceVersion:) -> Entity",
    "MastodonClient.post(endpoint:forceVersion:) -> Entity",
    "MastodonClient.put(endpoint:forceVersion:) -> Entity",
    "MastodonClient.delete(endpoint:forceVersion:) -> HTTPURLResponse?",
    "MastodonClient.oauthURL() -> URL",
    "MastodonClient.continueOauthFlow(url:) -> OauthToken",
    "MastodonClient.makeWebSocketTask(endpoint:instanceStreamingURL:) -> URLSessionWebSocketTask",
    "MastodonClient.mediaUpload(endpoint:version:method:mimeType:filename:data:) -> Entity",
    "Theme.applySet(set: ColorSetName)",
    "Theme.allColorSet: [ColorSet]",
    "Theme.restoreDefault()",
    "Router (environment object for navigation)",
    "CurrentAccount (environment object for active account state)",
    "AppAccountsManager (multi-account management)",
    "StreamWatcher (real-time streaming events)",
    "DeepLClient (translation API)",
    "OpenAIClient (AI-assisted features)"
  ]
}
